dati <- read.csv("data/captures.csv", sep=";")
dati2 <- na.omit(dati) # na.omit toglie TUTTE le righe che contengono almeno un NA
t.test(dati$footlength_mm ~ dati$sex)
plot(dati$footlength_mm ~ dati$sex)
plot(dati$footlength_mm, dati$sex)
