#Vettore di birre bevute
birref<-c(2, 2, 2, 2) #2 birre per ogni ragazza
birrem<-c(0, 1, 3, 4) #X birre per ogni ragazzo
#Stessa media
mean(birref)
mean(birrem)
#Stessa mediana
median(birref)
median(birrem)
#Le distribuzioni però sono diverse
#Campo di variazione (molto influenzabile dai dati)
max(birref)-min(birref)
max(birrem)-min(birrem)
#Scarto interquartile di birrem (Parte dal 1o al 3o quartile)
summary(birrem)
scarto<-3.25-0.75
#In alternativa si calcola con quantile
quantile(birrem, 0.75) - quantile(birrem, 0.25)
#Varianza (Quanto i dati si discostano dalla media)
var(birref) #Delle ragazze = 0
var(birrem) #Dei ragazzi
#Deviazione standard (Radice della varianza
#per tornare all'unità di misura originale)
sd(birrem) #Oppure sqrt(var(birrem))
#Coefficiente di variazione (Deviazione standard fratto |media|)
sd(birrem)/abs(mean(birrem))
#Def. eventi elementari
esiti<-c(1, 2, 3, 4, 5, 6)
esiti
length(esiti)
#Per generare un campione aleatorio
sample(esiti, size = 1) #Quante volte estrarre la sample con "size"
help(sample)
#"prob" indica la probabilità di ogni esito nel vettore
prob_esiti<-c(1/6, 1/6, 1/6, 1/6, 1/6, 1/6) #Ogni faccia del dado ha 1/6 di uscire
sample(esiti, size = 2, prob = prob_esiti)
#"replace" permette agli esiti di ripetersi con lanci successivi
sample(esiti, size = 10, replace = TRUE, prob = prob_esiti)
#Per inizializzare un metodo di scelta per sample()
set.seed(194739) #Le sequenze saranno uguali ogni volta che si esegue set.seed()
sample(esiti, size = 3, replace = TRUE, prob = prob_esiti)
#I possibili esiti
k<-1:6 #Vettore di interi tra 1 e 6 compresi
#Le probabilità di ogni esito
p<-c(1/length(k), 1/length(k), 1/length(k), 1/length(k), 1/length(k), 1/length(k))
#Grafico della distribuzione delle probabilità
plot(k, p, type="h", xlab="risultato dado", ylab="probabilità")
points(k, p, pch=20)
#Se voglio sapere la probabilità per X<=1, 2, 3, 4, 5, 6
p2<-c(p[1], 0, 0, 0, 0, 0)
for (i in 2:6) {
p2[i]=p2[i-1]+p[i]
}
plot(k, p2, type="h", xlab="risultato dado minore o uguale", ylab="probabilità")
points(k, p2, pch=20)
#Probabilità che ne passi esattamente 1, X=1
dpois(1, lambda = 2)
#Probabilità che X<1, ma ppois() lavora solo su <= o > quindi si fa
1 - ppois(0, lambda = 2) #1 (100%) - probabilità che X<=0
ppois(0, lambda = 2, lower.tail = F) # Probabilità X>0
#1.Prob di superare il test (distr. binomiale)
n = 10 #Domande
p = 0.25 #Probabilità di risposta giusta
X1 = dbinom(8, size = n, prob = p) + dbinom(9, size = n, prob = p) + dbinom(10, size = n, prob = p)
#Che è come dire
pbinom(7, size = n, prob = p, lower.tail = F)
#2. Stessa prob se la soglia fosse 6
X2 = pbinom(5, size = n, prob = p, lower.tail = F)
#3. Prob di dare tra le 4 e le 7 risposte giuste (prob X<=7 - prob X<=3)
X3 = pbinom(7, size = n, prob = p) - pbinom(3, size = n, prob = p)
#4. Quante risposte giuste mediamente se si risponde a caso e con quale varianza
X4 = qbinom(0.25, size = n, prob = p)
var(X4)
#5. Prob minima risposte giuste nel 50% dei casi
X5 = qbinom(0.5, size = n, prob = p)
#6. Test su un campione di 80 persone
X6 = rbinom(80, size = n, prob = p)
