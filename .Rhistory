#| label: prior-2009
# Creiamo il vettore di theta (prevalenza) da 0 a 1
d_2009 <- data.frame(
theta = seq(0, 1, by = 0.001),
density = dbeta(seq(0, 1, by = 0.001), 9, 55)
)
# Calcoliamo i parametri di posizione geometrica
n <- length(d_2009$density)
dx <- mean(diff(d_2009$theta))
y.unit <- sum(d_2009$density) * dx # Integrale (deve essere ~ 1)
dx <- dx / y.unit
x.mean <- sum(d_2009$density * d_2009$theta) * dx
x.mode <- d_2009$theta[which.max(d_2009$density)]
#| label: auc-2009
# Intero range (deve essere ~ 1)
total_auc <- auc(d_2009$theta, d_2009$density, type = 'spline')
# Probabilità che la prevalenza sia inferiore alla media attesa (0.14)
new_sub <- subset(d_2009, theta < 0.14)
p_under_mean <- auc(new_sub$theta, new_sub$density, type = 'spline')
total_auc
new_sub
p_under_mean
#| label: posterior-2009-calc
a <- 9; b <- 55
y <- 6; n <- 57
d_post_2009 <- data.frame(
theta = seq(0, 1, by = 0.001),
distribution = rep(c("prior", "posterior"), each = 1001),
density = c(dbeta(seq(0, 1, by = 0.001), a, b),
dbeta(seq(0, 1, by = 0.001), a + y, b + n - y))
)
??dbeta
??dbeta()
#| label: plot-comparison-2009
#| fig-align: center
#| fig-height: 4.5
ggplot(d_post_2009, aes(x = theta, y = density, color = distribution)) +
geom_line(size = 1.2) +
scale_color_manual(values = c("prior" = "grey", "posterior" = "black")) +
# xlim(0, 0.4) +
coord_cartesian(xlim = c(0, 0.4)) +
labs(title = "Aggiornamento Bayesiano nel 2009",
x = "Prevalenza", y = "Densità") +
theme_cowplot()
#| label: prior-2021
d_2021_prior <- data.frame(
theta = seq(0, 1, by = 0.001),
density = dbeta(seq(0, 1, by = 0.001), 15, 106)
)
#| label: posterior-2021-calc
a_2021 <- 15; b_2021 <- 106
y_2021 <- 41; n_2021 <- 172
d_post_2021 <- data.frame(
theta = seq(0, 1, by = 0.001),
distribution = rep(c("prior", "posterior"), each = 1001),
density = c(dbeta(seq(0, 1, by = 0.001), a_2021, b_2021),
dbeta(seq(0, 1, by = 0.001), a_2021 + y_2021, b_2021 + n_2021 - y_2021))
)
#| label: plot-comparison-2021
#| fig-align: center
#| fig-height: 4.5
ggplot(d_post_2021, aes(x = theta, y = density, color = distribution)) +
geom_line(size = 1.2) +
scale_color_manual(values = c("prior" = "purple", "posterior" = "darkred")) +
coord_cartesian(xlim = c(0, 0.4)) +
labs(title = "Aggiornamento Bayesiano nel 2021",
x = "Prevalenza di L. europaeus", y = "Densità") +
theme_cowplot()
#| label: final-comparison
#| fig-align: center
#| fig-height: 4.5
# Isoliamo le due distribuzioni a posteriori
post_2009 <- subset(d_post_2009, distribution == "posterior")
post_2021 <- subset(d_post_2021, distribution == "posterior")
comparison_df <- data.frame(
theta = post_2009$theta,
density_2009 = post_2009$density,
density_2021 = post_2021$density
)
#| label: plot-final-comparison
#| fig-align: center
#| fig-height: 4.5
ggplot(comparison_df) +
geom_line(aes(x = theta, y = density_2009, color = "2009"), size = 1.2) +
geom_line(aes(x = theta, y = density_2021, color = "2021"), size = 1.2) +
scale_color_manual(values = c("2009" = "darkgrey", "2021" = "black")) +
xlim(0, 0.4) +
labs(title = "Evoluzione della proporzione di lepre europea (2009 vs 2021)",
x = "Proporzione di campioni di L. europaeus", y = "Densità", color = "Anno") +
theme_minimal()
#| label: credible-intervals
# Calcolo dei quantili tramite somma cumulativa normalizzata
cumsum_2021 <- cumsum(post_2021$density) / sum(post_2021$density)
lower_bound <- post_2021$theta[which(cumsum_2021 >= 0.025)[1]]
upper_bound <- post_2021$theta[which(cumsum_2021 >= 0.975)[1] - 1]
