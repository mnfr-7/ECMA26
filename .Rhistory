ordine<-c("caffè", "caffè", "caffè", "caffè", "caffè", "caffè", "caffè",
"tè", "tè",
"orzo", "orzo", "orzo", "orzo",
"cioccolata", "cioccolata", "cioccolata", "cioccolata", "cioccolata")
