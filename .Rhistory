#Ipotesi nulla H0: m=m0
m0<-41.5
#lvl di significatività
alpha<-0.05
#Stipendi nel 2022
stipendi<-c(41.8, 43.4, 44.0, 34.2, 66.0, 77.5, 35.6,
38.2, 40.7, 33.3, 39.6, 36.2, 104.2, 41.9)
stipendi
median(stipendi)
#Ipotesi alternativa HA: m<m0 (M è la mediana reale nel 2022)
wilcox.test(stipendi, mu = m0, alternative = "less", exact = F)
#Dati, varianze e dimensioni
gruppoA<-c(8.7, 9.3, 11.5, 10.2, 9.7, 10.0, 11.0)
gruppoB<-c(9.0, 9.4, 10.0, 10.2, 9.9, 10.2, 10.5)
sigma2A<-2
sigma2B<-2
nA<-length(gruppoA)
nB<-length(gruppoB)
#Medie campionarie
xA<-mean(gruppoA); xA
xB<-mean(gruppoB); xB
#Statistica di test
z<-(xA-xB)/sqrt((sigma2A/nA)+(sigma2B/nB)); z
#Calcolo p-value
pvalue<-2*pnorm(z, lower.tail = F); pvalue
#Stesso problema con varianze incognite MA UGUALI
s2A<-var(gruppoA)
s2B<-var(gruppoB)
#Deviazione standard combinata
sc<-sqrt((((nA-1)*s2A)+((nB-1)*s2B))/(nA+nB-2)); sc
#Valore della statistica di test
t<-(xA-xB)/(sc*sqrt(1/nA+1/nB)); t
#Calcolo p-value
pvalue<-2*pt(t, df = nA+nB-2, lower.tail = F); pvalue
#Tutto questo corrisponde al fare (two.sided di default)
t.test(gruppoA, gruppoB, var.equal = T) #var.equal = TRUE perchè le varianze
rm(list=ls())
#Def vettore di dati per la var corso
corsoA<-c(12, 15)
corsoB<-c(25, 13)
#Def la tabella di contingenza
x_osservate<-rbind(corsoA, corsoB); x_osservate
#Calcolo marginali della var corso (somma dei valori della var)
margin_corso<-c(sum(corsoA), sum(corsoB)); margin_corso
#Def vettore dati per la var esame superato
sup_yes<-c(12, 25)
sup_no<-c(15, 13)
#Calcolo marginali della var esame
margin_esame<-c(sum(sup_yes), sum(sup_no)); margin_esame
#Taglia del campione
n<-sum(x_osservate); n
#Costruzione della tabella nel caso sia vera l'indipendenza tra le variabili
#Righe attese
attese_corsoA<-(margin_corso[1]/n)*(margin_esame/n)*n
attese_corsoB<-(margin_corso[2]/n)*(margin_esame/n)*n
#Def tabella delle x attese
x_attese<-rbind(attese_corsoA, attese_corsoB); x_attese
#Calcolo valore della statistica di test
chi2<-sum((x_osservate-x_attese)^2/x_attese); chi2
#Calcolo della probabilità
pchisq(chi2, df=1, lower.tail=F) #pvalue
#Ora con un unico comando
chisq.test(x_osservate) #Valori diversi per la correzione di continuità
chisq.test(x_osservate, correct=F)
#Con un lvl di significatività al 5%, pvalue = 0.08 > 0.05 (NON si rifiuta H0)
rm(list=ls())
#Proporzioni teoriche
pt<-c(0.2, 0.3, 0.3, 0.2) #Devono sommare a 1 (100%)
#Dati campionari su 100 votanti (frequenze)
f100<-c(19, 25, 25, 31)
#Calcolo chisq.test
chisq.test(f100, p=pt) #df (gradi di libertà) = n°partiti-1
#Provando a mantenere le proporzioni delle frequenze uguali ma su 1000 votanti
f1000<-c(190, 250, 250, 310)
chisq.test(f1000, p=pt) #il pvalue è minuscolo
#Vettore frequenze
f<-c(13, 17, 9, 17, 18, 26)
