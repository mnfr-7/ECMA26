#Carica il dataset sulle linci canadesi
data(lynx)
#Mostra info sul dataset
help(lynx)
#Visualizza il vettore
lynx
#Mostra che ogni elemento è rappresentativo di un anno dal 1821 al 1934
1934-1821+1 #Aggiunto 1 per contare il primo anno
length(lynx)
#Prova a rappresentare i dati delle frequenze su un barplot
#ma non è per nulla significativo in questo campione di dati
frequenza<-table(lynx)
barplot(frequenza)
#Rappresenta i dati su un istogramma per avere un'idea approssimata
#di quante linci sono state catturate con quale frequenza
hist(lynx, breaks = 14) #breaks per scegliere quante classi rappresentare
barplot(frequenza)
#Rappresenta i dati su un istogramma per avere un'idea approssimata
#di quante linci sono state catturate con quale frequenza
hist(lynx, breaks = 14) #breaks per scegliere quante classi rappresentare
#Calcola la media delle linci catturate in totale
mean(lynx)
#Ordina i dati e calcola la mediana (media tra i due valori centrali)
lynx_ord<-sort(lynx)
lynx_ord[57]
lynx_ord[58]
median(lynx_ord)
#Calcola il percentile in base alla percentuale specificata in probs
quantile(lynx, probs = 0.33)
#Calcola i quartili (percentili ogni 25%)
summary(lynx)
#Carica set di dati sui fiumi e mostra le info
data(rivers)
help(rivers)
rivers #Vettore di lunghezze di 141 fiumi in Nord America (in miglia)
#Media
mean(rivers)
#Mediana
median(rivers)
#Quartili
summary(rivers)
#Rappresentazione grafica dei quartili
boxplot(rivers, horizontal = TRUE) #Con valori anomali
boxplot(rivers, horizontal = TRUE, outline = FALSE) #Senza outliers
#Mostra solo i fiumi più corti di 600 miglia in ordine
sort(rivers[rivers<600])
#Mostra solo i fiumi compresi tra le 300 e le 1000 miglia
sort(rivers[rivers>300&rivers<1000])
