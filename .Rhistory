#1. Campione
x<-c(8, 17, 10, 11, 13, 7, 14, 19, 5, 6, 10, 13, 12, 15, 8, 7, 7, 11, 15, 18, 10, 9, 6,
11, 20, 9, 16, 13, 10, 12, 6, 9, 19)
#2. Media campionaria
mean(x)
#3. Lunghezza del campione >30?
n<-length(x)
n #33 > 30, la distribuzione della media approx con t di Studenti con n-1 gradi
#di libertà
#4. Intervallo di confidenza con t.test
t.test(x) #Al 95% è (9.908, 12.880)
#Cosa succede se aumenta il livello di fiducia es. 99%
t.test(x, conf.level = 0.99) #Più grande perchè richiediamo maggior fiducia
rm(list=ls())
#Totale
n<-580; n
#Proporzione campionaria
prop<-0.26; prop
#Verifica ipotesi normalità (n*prop>=5, n*(1-prop)>=5)
n*prop #151>5
n*(1-prop) #429>5
#Intervallo al 95% (default)
x<-0.26*580
prop.test(x, n) #(0.22, 0.30)
conf_int_95<-c(0.22, 0.30); conf_int_95
#Oppure calcolo esatto
alpha<-0.05
z<-qnorm(1-alpha/2); z #1.96 | Quantile della distribuzione normale standard
eps<-z*sqrt(prop*(1-prop)/n); eps #0.04 | Errore statistico epsilon
IC95<-c(prop-eps, prop+eps) #(0.22, 0.30)
#Cambiando il lvl di confidenza?
prop.test(x, n, conf.level = 0.99) #Intervallo più grande (0.21, 0.31)
#Raddoppiando l'ampiezza del campione?
prop.test(x*2, n*2) #Int più piccolo (0.24, 0.29)
